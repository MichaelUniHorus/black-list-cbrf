# Database (Production - external PostgreSQL on server)
DATABASE_URL=postgresql://openblack:your-secure-password-here@localhost:5432/openblack

# Redis
REDIS_URL=redis://redis:6379/0

# Yandex Maps API
# Получить ключ: https://developer.tech.yandex.ru/
YANDEX_MAPS_API_KEY=your-yandex-maps-api-key-here

# App Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
CORS_ORIGINS=https://mikesdemos.ru

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
