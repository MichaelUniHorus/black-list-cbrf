# Database (Production - PostgreSQL in Docker)
POSTGRES_USER=openblack
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=openblack
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379/0

# Yandex Maps API
# Получить ключ: https://developer.tech.yandex.ru/
YANDEX_MAPS_API_KEY=your-yandex-maps-api-key-here

# App Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
CORS_ORIGINS=https://mikesdemos.ru,http://mikesdemos.ru

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
